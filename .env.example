# =============================================================================
# SceneRx — docker-compose environment
# Copy to `.env` and edit. ONLY the LLM API key is strictly required to start.
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# 1. LLM provider — pick ONE and fill in the matching key.
# -----------------------------------------------------------------------------
# Provider must match a non-empty key below. Options: gemini | openai | anthropic | deepseek
LLM_PROVIDER=gemini

GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# -----------------------------------------------------------------------------
# 2. Vision API — segmentation + depth.
# -----------------------------------------------------------------------------
# Three deployment patterns:
#
#   (a) Local container (NVIDIA GPU required):
#         docker compose --profile gpu up -d
#       Then leave VISION_API_URL at the default below.
#
#   (b) Remote endpoint (Hugging Face Space, Colab tunnel, lab GPU host):
#         VISION_API_URL=https://YOUR-SPACE.hf.space/api
#       Don't pass --profile gpu; the local vision-api stays off.
#
#   (c) Skip vision entirely (test other stages with mocks):
#         VISION_API_URL=http://localhost:8000   # any unreachable URL
VISION_API_URL=http://vision-api:8000

# Pin a specific tag of the published vision image (recommended for reproducibility).
# Browse tags at: https://github.com/ZhenGtai123/scenerx/pkgs/container/scenerx-vision
VISION_IMAGE_TAG=latest
# Override the image registry/name if you've forked / mirrored elsewhere:
# SCENERX_VISION_IMAGE=ghcr.io/your-fork/scenerx-vision

# Depth model loaded by the Vision API at startup.
#   DA3METRIC-LARGE              (default, 0.35B params, ~8 GB VRAM)
#   DA3NESTED-GIANT-LARGE-1.1    (1.4B params, ~16 GB VRAM, higher accuracy)
VISION_DEPTH_MODEL=DA3METRIC-LARGE

# -----------------------------------------------------------------------------
# 3. Security — change for any non-local deployment.
# -----------------------------------------------------------------------------
# Generate with:  openssl rand -hex 32
SECRET_KEY=CHANGE_ME_RUN_openssl_rand_hex_32

# -----------------------------------------------------------------------------
# 4. Postgres credentials (only matters if you expose the DB beyond localhost)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=scenerx

# -----------------------------------------------------------------------------
# 5. Release pin — set to a git tag (e.g. v0.1.0) to tag built images
# -----------------------------------------------------------------------------
SCENERX_VERSION=dev
