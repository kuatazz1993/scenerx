          "superposition",
          "weaving",
          "deformation",
          "reduction",
          "montage",
          "collage"
        ],
        "theoretical_basis": "Steenbergen & Reh, 2003",
        "usage_count": 109,
        "pattern_codes": [
          "PAT_SUP",
          "PAT_WEA",
          "PAT_DEF",
          "PAT_RED",
          "PAT_MON",
          "PAT_COL"
        ]
      },
      "SCP_S3": {
        "name": "Strategic",
        "definition": "Phased programme: multiple operations sequenced over time",
        "theoretical_basis": "Braae, 2015; Corner, 1999",
        "usage_count": 3,
        "pattern_codes": [
          "PAT_PTV"
        ]
      }
    },
    "excluded": {
      "OBJ_SKY": {
        "reason": "Designers cannot physically alter sky; SVF changes are captured by operations on VEG/BLT"
      }
    },
    "roles": {
      "ROL_PRI": {
        "name": "Primary",
        "definition": "Principal operative component driving the intended indicator change within a multi-signature intervention.",
        "usage_count": 294
      },
      "ROL_SEC": {
        "name": "Secondary",
        "definition": "Supporting but still material component that co-produces the intended effect alongside the primary signature.",
        "usage_count": 153
      },
      "ROL_SUP": {
        "name": "Supporting",
        "definition": "Auxiliary component that stabilizes, reinforces, or enriches the main intervention logic without serving as the principal driver.",
        "usage_count": 15
      },
      "ROL_TER": {
        "name": "Tertiary",
        "definition": "Third-order component included when an intervention requires more than two coordinated signatures.",
        "usage_count": 5
      },
      "ROL_CTX": {
        "name": "Contextual",
        "definition": "Context-setting component that shapes background conditions or framing rather than acting as the direct intervention target.",
        "usage_count": 3
      },
      "ROL_MOD": {
        "name": "Modulating",
        "definition": "Component that tunes the magnitude, exposure, or perceptual intensity of the main intervention effect.",
        "usage_count": 2
      },
      "ROL_COM": {
        "name": "Complementary",
        "definition": "Component that contributes a compatible parallel benefit while not being strictly required for the core mechanism.",
        "usage_count": 1
      },
      "ROL_ENB": {
        "name": "Enabling",
        "definition": "Prerequisite component that makes the main intervention feasible or legible.",
        "usage_count": 1
      },
      "ROL_ANC": {
        "name": "Ancillary",
        "definition": "Minor add-on component with limited direct causal weight but possible co-benefits.",
        "usage_count": 1
      }
    },
    "scope_patterns": {
      "PAT_SUP": {
        "name": "superposition",
        "scope_id": "SCP_S2",
        "definition": "Two or more signatures are layered onto the same visual field or spatial support so that added material overlays, screens, or co-occupies an existing carrier."
      },
      "PAT_WEA": {
        "name": "weaving",
        "scope_id": "SCP_S2",
        "definition": "Multiple signatures are interlaced across the scene, alternating or distributing complementary elements to create a composite visual structure."
      },
      "PAT_DEF": {
        "name": "deformation",
        "scope_id": "SCP_S2",
        "definition": "The intervention reshapes an existing element or spatial edge rather than merely adding or removing components."
      },
      "PAT_RED": {
        "name": "reduction",
        "scope_id": "SCP_S2",
        "definition": "The coordinated logic relies on subtracting or visually down-weighting one set of elements to reveal or strengthen another."
      },
      "PAT_MON": {
        "name": "montage",
        "scope_id": "SCP_S2",
        "definition": "Distinct signatures are assembled as juxtaposed fragments that collectively alter scene perception through composition."
      },
      "PAT_COL": {
        "name": "collage",
        "scope_id": "SCP_S2",
        "definition": "Heterogeneous signatures are combined in a patchwork manner while retaining visible differentiation between components."
      },
      "PAT_PTV": {
        "name": "phased_temporal_vegetation_layering",
        "scope_id": "SCP_S3",
        "definition": "A strategic sequence in which vegetation layers are introduced or matured over time to progressively reshape the visual field."
      }
    },
