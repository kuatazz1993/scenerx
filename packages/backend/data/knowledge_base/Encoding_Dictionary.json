    "LCZ_B": {
      "name": "LCZ B - Scattered Trees",
      "definition": "Local Climate Zone B represents a landscape featuring a sparse arrangement of trees set against a background of low plant cover, such as grass or shrubs. The tree canopy is open, allowing sunlight to reach the permeable soil surface freely. This zone is typical of parklands, savannas, or agricultural estates with scattered orchards. While it offers some shading and cooling benefits through evapotranspiration, the thermal regulation is less intense than in dense forests (LCZ A) due to increased solar exposure on the ground surface.",
      "supporting_papers": [],
      "first_confirmed_by": "Song, B. (2023). Comparison of thermal environments and classification of physical environments using fisheye images with object-based classification. Urban Climate, 49, 101510.",
      "confirmation_count": 2,
      "definition_source": "LLM_expanded"
    },
    "LCZ_UNSPECIFIED": {
      "name": "Unspecified Local Climate Zone",
      "definition": "A category used when available land use or morphological data is insufficient to assign a specific Local Climate Zone (LCZ 1-10 or A-G). This designation indicates that properties such as building height, sky view factor, or surface cover fraction could not be determined with enough confidence to meet the Stewart & Oke classification standards.",
