    "IND_WAL": {
      "name": "Wall Ratio",
      "definition": "IND_WAL assesses the vertical enclosure of a space by determining the proportion of the visual field occupied by walls, building facades, or solid barriers. This indicator helps quantify the 'canyon effect' in urban planning and influences the psychological feeling of confinement or security. By measuring the ratio of vertical solid surfaces, researchers can evaluate the relationship between built edges and the pedestrian scale, which directly impacts the visual complexity and perceived density of an architectural environment.",
      "category": "CAT_CMP",
      "formula": "Pixel_Wall / Total_Pixels",
      "variables": {
        "Pixel_Wall": "Number of pixels classified as wall/fence",
