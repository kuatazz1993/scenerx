    "LCZ_3": {
      "name": "LCZ 3 - Compact Low-rise",
      "definition": "Local Climate Zone 3 features a dense collection of low-rise buildings, typically one to three stories tall. These structures are often attached or separated by very narrow alleys, maximizing building coverage within the lot. The surrounding ground surface is primarily paved with hard materials, offering minimal pervious land cover or vegetation. Due to the high density of small structures and lack of greenery, this zone experiences reduced airflow and significant thermal retention. It is representative of historic city centers, dense residential suburbs, or informal settlements where land use is extremely intensive.",
      "category": "CAT_CTX",
      "supporting_papers": [],
      "first_confirmed_by": "Hua, J., Cai, M., Shi, Y., Ren, C., Xie, J., Chung, L. C. H., ... & Webster, C. (2022). Investigating pedestrian-level greenery in urban forms in a high-density city for urban planning. Sustainable Cities and Society, 80, 103755.",
      "confirmation_count": 4,
      "definition_source": "LLM_expanded"
    },
