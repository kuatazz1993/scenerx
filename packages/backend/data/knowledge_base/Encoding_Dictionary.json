    "IND_FNC": {
      "name": "Fence Ratio",
      "definition": "IND_FNC quantifies the visual prominence of boundary markers, specifically focusing on fences, railings, and gates. It is calculated as the proportion of the view plane covered by these dividing structures. This indicator is significant in environmental psychology and crime prevention through environmental design (CPTED) as it relates to territoriality, privacy, and visual permeability. A high fence ratio may indicate a defensive spatial character, affecting social interaction and the aesthetic continuity between private properties and the public realm.",
      "category": "CAT_CMP",
      "supporting_papers": [
        {
          "paper_file": "Zhang, Y",
          "doi": "10.1016/j.landusepol.2021.105762",
