      "recommended_unit": "coef",
      "definition_source": "project_patch"
    },
    "Unstandardized B": {
      "name": "Unstandardized regression coefficient (B)",
      "definition": "Unstandardized regression coefficient (B). In linear models, it represents the expected change in the outcome (in its original units) for a one-unit increase in the predictor, holding other variables constant.",
